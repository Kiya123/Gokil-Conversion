# ============================================================
#  SERVER .env — Gokil Conversion
#  Copy file ini jadi ".env" lalu isi nilainya
# ============================================================

# --- Database (MySQL via XAMPP) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gokil_conversion
DB_USER=root
DB_PASS=

# --- Mode koneksi: "local" atau "ngrok" ---
# Dipakai untuk menentukan UPLOAD_URL_BASE yang benar
CONNECTION_MODE=ngrok

# --- Mode LOCAL ---
# URL base untuk akses file hasil konversi via LAN
LOCAL_UPLOAD_URL=http://192.168.1.100/gokil-conversion/server/uploads/

# --- Mode NGROK ---
# Ganti URL ini setiap sesi ngrok baru
NGROK_URL=https://xxxx-xxxx-xxxx.ngrok-free.app

# --- File Validation ---
MAX_FILE_SIZE_MB=10
