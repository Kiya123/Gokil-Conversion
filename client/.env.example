# ============================================================
#  CLIENT .env — Gokil Conversion
#  Copy file ini jadi ".env" lalu isi nilainya
# ============================================================

# Toggle mode koneksi: "local" atau "ngrok"
CONNECTION_MODE=ngrok

# --- Mode LOCAL (LAN via Hotspot HP) ---
# Cara cari IP Azkiya: CMD → ipconfig → IPv4 Address
LOCAL_SERVER_IP=192.168.1.100
LOCAL_SERVER_PORT=80

# --- Mode NGROK ---
# Cara dapat URL: jalankan "ngrok http 80" di laptop Azkiya
# Ganti URL ini setiap sesi ngrok baru (URL berubah tiap restart)
NGROK_BASE_URL=https://xxxx-xxxx-xxxx.ngrok-free.app

# --- File Validation ---
MAX_FILE_SIZE_MB=10

# --- cURL Timeout (detik) ---
# Rekomendasi: 60 untuk ngrok, 30 untuk local
CURL_TIMEOUT_SEC=60
